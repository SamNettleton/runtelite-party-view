{
  "name": "runelite-party-view",
  "private": true,
  "version": "1.0.2",
  "description": "A live party view for RuneLite",
  "author": "Sam Nettleton",
  "repository": {
    "type": "git",
    "url": "https://github.com/samnettleton/runelite-party-view"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "package": "npm run build && electron-builder",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "proto:js": "pbjs -t static-module -w es6 -o src/hooks/party_pb.js src/hooks/party.proto",
    "proto:ts": "pbts -o src/hooks/party_pb.d.ts src/hooks/party_pb.js",
    "proto": "npm run proto:js && npm run proto:ts"
  },
  "dependencies": {
    "protobufjs": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^27.2.0",
    "electron-builder": "^24.6.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "prettier": "^3.8.2",
    "protobufjs-cli": "^2.0.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.runelite.partyview",
    "publish": [
      {
        "provider": "github",
        "owner": "samnettleton",
        "repo": "runelite-party-view"
      }
    ],
    "productName": "RuneLite Party View",
    "files": [
      "dist/**",
      "electron/main.cjs",
      "electron/preload.cjs",
      "node_modules/**"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "Sam Nettleton",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Sam Nettleton <nettleton.sam@gmail.com>",
      "category": "Utility",
      "icon": "build/icon.png"
    }
  }
}
